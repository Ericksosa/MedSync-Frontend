@using MedSync_Frontend.Models.ViewModels
@{
    ViewData["Title"] = "Reservar Cita";
    var hospitales = ViewBag.Hospitales as List<HospitalViewModel> ?? [];
    var paciente = ViewBag.Paciente as PacienteViewModel;
}

<div class="max-w-4xl mx-auto">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-slate-800">Reservar Cita</h1>
        <p class="text-slate-500 text-sm mt-1">Completa los detalles para agendar tu consulta.</p>
    </div>

    <!-- Stepper -->
    <div class="flex items-center gap-4 mb-8">
        @foreach (var (label, num) in new[] { ("Seleccionar Info", "1"), ("Horario", "2"), ("Confirmación", "3") })
        {
            <div class="flex items-center gap-2" id="step-indicator-@num">
                <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold step-circle-@num bg-blue-600 text-white shadow-sm">@num</div>
                <span class="text-sm font-semibold step-label-@num text-slate-700">@label</span>
            </div>
            if (num != "3") { <div class="flex-1 h-px bg-slate-200 step-line-@num"></div> }
        }
    </div>

    <!-- Step 1: Seleccionar Info -->
    <div id="step1" class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
        <div class="grid grid-cols-2 gap-4 mb-6">
            <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1 flex items-center gap-1.5"><i data-lucide="building-2" class="w-3.5 h-3.5"></i> Centro Médico</label>
                <select id="selectHospital" class="w-full px-3 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400">
                    <option value="">Seleccionar hospital...</option>
                    @foreach (var h in hospitales)
                    {
                        <option value="@h.Id">@h.Nombre</option>
                    }
                </select>
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1 flex items-center gap-1.5"><i data-lucide="stethoscope" class="w-3.5 h-3.5"></i> Especialidad</label>
                <select id="selectEspecialidad" class="w-full px-3 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" disabled>
                    <option value="">Seleccionar especialidad...</option>
                </select>
            </div>
        </div>

        <!-- Doctor cards -->
        <div id="medicosContainer" class="hidden">
            <h3 class="text-sm font-semibold text-slate-600 mb-3">Médicos disponibles</h3>
            <div id="medicosList" class="grid gap-3"></div>
        </div>

        <div class="flex justify-end mt-6">
            <button id="btnSiguiente1" disabled onclick="irPaso2()"
                    class="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 disabled:bg-slate-200 disabled:text-slate-400 text-white text-sm font-semibold px-6 py-2.5 rounded-xl transition-colors">
                Siguiente <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </button>
        </div>
    </div>

    <!-- Step 2: Horario -->
    <div id="step2" class="hidden bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
        <h3 class="font-semibold text-slate-800 mb-1">Escoger Fecha y Hora</h3>
        <p class="text-sm text-slate-400 mb-4">Selecciona un día disponible</p>

        <!-- Week navigation -->
        <div class="flex items-center justify-between mb-4">
            <button onclick="semanaAnterior()" class="p-2 hover:bg-slate-50 rounded-lg text-slate-500">‹</button>
            <span id="semanaLabel" class="text-sm font-semibold text-slate-700"></span>
            <button onclick="semanaSiguiente()" class="p-2 hover:bg-slate-50 rounded-lg text-slate-500">›</button>
        </div>

        <!-- Days -->
        <div id="diasSemana" class="grid grid-cols-7 gap-2 mb-6"></div>

        <!-- Time slots -->
        <div id="horasContainer" class="hidden">
            <h4 class="text-sm font-medium text-slate-600 mb-3 flex items-center gap-1.5"><i data-lucide="clock" class="w-4 h-4 text-blue-500"></i> Horas Disponibles</h4>
            <div id="horasList" class="flex flex-wrap gap-2"></div>
        </div>

        <div class="flex justify-between mt-6">
            <button onclick="irPaso1()" class="text-sm text-slate-500 hover:text-slate-700 px-4 py-2.5">← Volver</button>
            <button id="btnSiguiente2" disabled onclick="irPaso3()"
                    class="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 disabled:bg-slate-200 disabled:text-slate-400 text-white text-sm font-semibold px-6 py-2.5 rounded-xl transition-colors">
                Siguiente <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </button>
        </div>
    </div>

    <!-- Step 3: Confirmación -->
    <div id="step3" class="hidden bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
        <h3 class="font-semibold text-slate-800 mb-4">Confirmar Cita</h3>

        <div class="bg-blue-50 rounded-xl p-4 mb-4 space-y-2 text-sm">
            <div class="flex justify-between"><span class="text-slate-500">Hospital</span><span id="conf-hospital" class="font-medium text-slate-800"></span></div>
            <div class="flex justify-between"><span class="text-slate-500">Especialidad</span><span id="conf-especialidad" class="font-medium text-slate-800"></span></div>
            <div class="flex justify-between"><span class="text-slate-500">Médico</span><span id="conf-medico" class="font-medium text-slate-800"></span></div>
            <div class="flex justify-between"><span class="text-slate-500">Fecha y Hora</span><span id="conf-fechahora" class="font-medium text-slate-800"></span></div>
        </div>

        <div class="mb-4">
            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Notas (opcional)</label>
            <textarea id="notasCita" rows="3" placeholder="Motivo de la consulta, síntomas, etc."
                      class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 resize-none"></textarea>
        </div>

        <form id="formCita" asp-controller="Paciente" asp-action="ReservarCita" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="PacienteId" id="hf-pacienteId" value="@paciente?.Id" />
            <input type="hidden" name="MedicoId" id="hf-medicoId" />
            <input type="hidden" name="HospitalId" id="hf-hospitalId" />
            <input type="hidden" name="FechaHora" id="hf-fechahora" />
            <input type="hidden" name="Notas" id="hf-notas" />

            <div class="flex justify-between">
                <button type="button" onclick="irPaso2()" class="text-sm text-slate-500 hover:text-slate-700 px-4 py-2.5">← Volver</button>
                <button type="submit" onclick="prepararEnvio()"
                        class="bg-green-600 hover:bg-green-700 text-white text-sm font-semibold px-6 py-2.5 rounded-xl flex items-center gap-2 transition-colors shadow-sm">
                    Confirmar cita <i data-lucide="check-circle-2" class="w-4 h-4"></i>
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
let selHospitalId = null, selHospitalNombre = '';
let selEspId = null, selEspNombre = '';
let selMedicoId = null, selMedicoNombre = '';
let selFechaHora = null;
let disponibilidad = [];
let semanaOffset = 0;

// ─── Cascading dropdowns ───
$('#selectHospital').on('change', async function () {
    selHospitalId = this.value;
    selHospitalNombre = $(this).find('option:selected').text();
    selEspId = null; selMedicoId = null;
    $('#selectEspecialidad').html('<option value="">Cargando...</option>').prop('disabled', true);
    $('#medicosContainer').addClass('hidden');
    $('#btnSiguiente1').prop('disabled', true);

    if (!selHospitalId) return;
    const data = await fetch(`/Paciente/ObtenerEspecialidades?hospitalId=${selHospitalId}`).then(r => r.json());
    let opts = '<option value="">Seleccionar especialidad...</option>';
    data.forEach(e => opts += `<option value="${e.id}">${e.nombre}</option>`);
    $('#selectEspecialidad').html(opts).prop('disabled', false);
});

$('#selectEspecialidad').on('change', async function () {
    selEspId = this.value;
    selEspNombre = $(this).find('option:selected').text();
    selMedicoId = null;
    $('#medicosContainer').addClass('hidden');
    $('#btnSiguiente1').prop('disabled', true);
    if (!selEspId) return;

    const data = await fetch(`/Paciente/ObtenerMedicos?hospitalId=${selHospitalId}&especialidadId=${selEspId}`).then(r => r.json());
    let html = '';
    data.forEach(m => {
        html += `<div class="flex items-center justify-between p-4 border border-slate-200 rounded-xl hover:border-blue-300 cursor-pointer medico-card"
                      data-id="${m.id}" data-nombre="${m.nombreCompleto}" onclick="seleccionarMedico(${m.id}, '${m.nombreCompleto}', this)">
            <div>
                <div class="font-semibold text-slate-800">${m.nombreCompleto}</div>
                <div class="text-sm text-blue-600">${m.nombreEspecialidad}</div>
            </div>
            <div class="w-4 h-4 rounded-full border-2 border-slate-300 check-circle"></div>
        </div>`;
    });
    $('#medicosList').html(html || '<p class="text-slate-400 text-sm">No hay médicos disponibles.</p>');
    $('#medicosContainer').removeClass('hidden');
});

async function seleccionarMedico(id, nombre, el) {
    selMedicoId = id; selMedicoNombre = nombre;
    $('.medico-card').removeClass('border-blue-500 bg-blue-50');
    $('.check-circle').removeClass('bg-blue-600 border-blue-600');
    $(el).addClass('border-blue-500 bg-blue-50');
    $(el).find('.check-circle').addClass('bg-blue-600 border-blue-600');
    $('#btnSiguiente1').prop('disabled', false);

    disponibilidad = await fetch(`/Paciente/ObtenerDisponibilidad?medicoId=${id}`).then(r => r.json());
}

// ─── Steps ───
function irPaso1() { showStep(1); }
function irPaso2() { showStep(2); renderSemana(); }
function irPaso3() {
    showStep(3);
    $('#conf-hospital').text(selHospitalNombre);
    $('#conf-especialidad').text(selEspNombre);
    $('#conf-medico').text(selMedicoNombre);
    $('#conf-fechahora').text(formatFecha(selFechaHora));
}

function showStep(n) {
    ['step1','step2','step3'].forEach((id, i) => {
        const el = document.getElementById(id);
        el.classList.toggle('hidden', i+1 !== n);
    });
}

// ─── Calendar ───
const DIAS = ['Lun','Mar','Mié','Jue','Vie','Sáb','Dom'];
const MESES = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];

function getMondayOfWeek(offset) {
    const today = new Date();
    const day = today.getDay();
    const diff = (day === 0 ? -6 : 1 - day); // Monday
    const mon = new Date(today);
    mon.setDate(today.getDate() + diff + (offset * 7));
    mon.setHours(0,0,0,0);
    return mon;
}

function renderSemana() {
    const mon = getMondayOfWeek(semanaOffset);
    const sun = new Date(mon); sun.setDate(mon.getDate() + 6);
    const lbl = `${mon.getDate()} ${MESES[mon.getMonth()]} – ${sun.getDate()} ${MESES[sun.getMonth()]} ${sun.getFullYear()}`;
    $('#semanaLabel').text(lbl);

    let html = '';
    for (let i = 0; i < 7; i++) {
        const d = new Date(mon); d.setDate(mon.getDate() + i);
        const today = new Date(); today.setHours(0,0,0,0);
        const isPast = d < today;
        const diaSemana = i; // 0=Lun
        const tieneDisp = disponibilidad.some(x => x.diaSemana === diaSemana);
        const cls = isPast ? 'opacity-40 cursor-not-allowed' :
                    tieneDisp ? 'hover:bg-blue-50 hover:border-blue-400 cursor-pointer' : 'opacity-40 cursor-not-allowed';

        html += `<div class="flex flex-col items-center py-3 border border-slate-200 rounded-xl ${cls}"
                      onclick="${!isPast && tieneDisp ? `seleccionarDia(${d.getFullYear()},${d.getMonth()},${d.getDate()},${diaSemana})` : ''}">
            <span class="text-xs text-slate-400">${DIAS[i]}</span>
            <span class="text-base font-semibold mt-1">${d.getDate()}</span>
            ${tieneDisp && !isPast ? '<span class="w-1.5 h-1.5 rounded-full bg-blue-500 mt-1"></span>' : ''}
        </div>`;
    }
    $('#diasSemana').html(html);
    $('#horasContainer').addClass('hidden');
    selFechaHora = null;
    $('#btnSiguiente2').prop('disabled', true);
}

function semanaAnterior() { semanaOffset--; renderSemana(); }
function semanaSiguiente() { semanaOffset++; renderSemana(); }

function seleccionarDia(y, m, d, diaSemana) {
    const slots = disponibilidad.filter(x => x.diaSemana === diaSemana);
    let html = '';
    slots.forEach(s => {
        // Generate time slots every 30 min within the range
        let [sh, sm] = s.horaInicio.split(':').map(Number);
        const [eh, em] = s.horaFin.split(':').map(Number);
        while (sh * 60 + sm < eh * 60 + em) {
            const label = `${String(sh).padStart(2,'0')}:${String(sm).padStart(2,'0')}`;
            const dt = new Date(y, m, d, sh, sm);
            html += `<button class="px-4 py-2 border border-slate-200 rounded-xl text-sm hover:bg-blue-600 hover:text-white hover:border-blue-600 transition-colors slot-btn"
                             onclick="seleccionarHora('${dt.toISOString()}', '${label}', this)">${label}</button>`;
            sm += 30; if (sm >= 60) { sh++; sm -= 60; }
        }
    });
    $('#horasList').html(html || '<p class="text-slate-400 text-sm">Sin horarios disponibles este día.</p>');
    $('#horasContainer').removeClass('hidden');
}

function seleccionarHora(iso, label, el) {
    selFechaHora = iso;
    $('.slot-btn').removeClass('bg-blue-600 text-white border-blue-600');
    $(el).addClass('bg-blue-600 text-white border-blue-600');
    $('#btnSiguiente2').prop('disabled', false);
}

function formatFecha(iso) {
    if (!iso) return '';
    const d = new Date(iso);
    return d.toLocaleDateString('es-DO', { weekday:'long', year:'numeric', month:'long', day:'numeric' }) +
           ' ' + d.toLocaleTimeString('es-DO', { hour:'2-digit', minute:'2-digit' });
}

function prepararEnvio() {
    $('#hf-medicoId').val(selMedicoId);
    $('#hf-hospitalId').val(selHospitalId);
    $('#hf-fechahora').val(selFechaHora);
    $('#hf-notas').val($('#notasCita').val());
}
</script>
}

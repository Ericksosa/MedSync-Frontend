@using MedSync_Frontend.Models.ViewModels
@{
    ViewData["Title"] = "Usuarios del Sistema";
    var usuarios = ViewBag.Usuarios as List<UsuarioViewModel> ?? [];
    var porRol = usuarios.GroupBy(u => u.Rol).ToDictionary(g => g.Key, g => g.ToList());
}

<div class="max-w-5xl mx-auto space-y-6">

    <div>
        <div class="flex items-center gap-2 mb-1">
            <span class="px-2.5 py-0.5 bg-indigo-100 text-indigo-700 text-xs font-bold rounded-full uppercase tracking-wider">Solo lectura</span>
        </div>
        <h1 class="text-2xl font-bold text-slate-800">Usuarios del Sistema</h1>
        <p class="text-slate-500 text-sm mt-1">Visión global de todas las cuentas registradas en MedSync.</p>
    </div>

    <!-- Stat cards por rol -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        @foreach (var (rol, icon, bg, fg) in new[] {
            ("SuperAdmin",    "shield",       "bg-purple-50", "text-purple-600"),
            ("Administrador", "user-cog",     "bg-indigo-50", "text-indigo-600"),
            ("Doctor",        "stethoscope",  "bg-blue-50",   "text-blue-600"),
            ("Paciente",      "user",         "bg-green-50",  "text-green-600"),
        })
        {
            var count = porRol.ContainsKey(rol) ? porRol[rol].Count : 0;
            <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
                <div class="w-10 h-10 @bg rounded-xl flex items-center justify-center @fg mb-3">
                    <i data-lucide="@icon" class="w-5 h-5"></i>
                </div>
                <p class="text-xs text-slate-400 font-semibold uppercase tracking-wider">@rol</p>
                <p class="text-3xl font-bold text-slate-800 mt-1">@count</p>
            </div>
        }
    </div>

    @if (!usuarios.Any())
    {
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-10 text-center">
            <div class="w-14 h-14 bg-indigo-50 rounded-2xl flex items-center justify-center mx-auto mb-3">
                <i data-lucide="users" class="w-7 h-7 text-indigo-300"></i>
            </div>
            <p class="text-slate-500 font-medium">No hay usuarios registrados</p>
            <p class="text-xs text-slate-400 mt-1">O el endpoint <code>/api/auth/users</code> no está disponible aún en el backend.</p>
        </div>
    }
    else
    {
        <!-- Tabla de usuarios -->
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
            <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
                <h3 class="font-semibold text-slate-800">Todos los Usuarios</h3>
                <span class="text-sm text-slate-400">@usuarios.Count en total</span>
            </div>
            <table class="w-full text-sm">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Usuario</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Email</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Rol</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Estado</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Registrado</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var u in usuarios.OrderBy(u => u.Rol))
                    {
                        var (rolBg, rolFg) = u.Rol switch {
                            "SuperAdmin"    => ("bg-purple-100", "text-purple-700"),
                            "Administrador" => ("bg-indigo-100", "text-indigo-700"),
                            "Doctor"        => ("bg-blue-100",   "text-blue-700"),
                            _               => ("bg-green-100",  "text-green-700")
                        };
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-5 py-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-7 h-7 bg-slate-100 rounded-full flex items-center justify-center text-xs font-bold text-slate-500 flex-shrink-0">
                                        @(u.NombreCompleto.Length > 0 ? u.NombreCompleto[0].ToString().ToUpper() : "?")
                                    </div>
                                    <span class="font-medium text-slate-700">@u.NombreCompleto</span>
                                </div>
                            </td>
                            <td class="px-5 py-3 text-slate-500">@u.Email</td>
                            <td class="px-5 py-3">
                                <span class="px-2.5 py-1 rounded-full text-xs font-semibold @rolBg @rolFg">@u.Rol</span>
                            </td>
                            <td class="px-5 py-3">
                                <span class="px-2.5 py-1 rounded-full text-xs font-semibold @(u.EstaActivo ? "bg-green-100 text-green-700" : "bg-red-100 text-red-600")">
                                    @(u.EstaActivo ? "Activo" : "Inactivo")
                                </span>
                            </td>
                            <td class="px-5 py-3 text-slate-400 text-xs">@u.CreadoEn.ToString("dd/MM/yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

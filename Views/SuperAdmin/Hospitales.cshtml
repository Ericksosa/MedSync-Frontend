@using MedSync_Frontend.Models.ViewModels
@{
    ViewData["Title"] = "Gestión Global de Hospitales";
    var hospitales = ViewBag.Hospitales as List<HospitalViewModel> ?? [];
}

<div class="max-w-5xl mx-auto space-y-6">

    <div class="flex items-start justify-between">
        <div>
            <div class="flex items-center gap-2 mb-1">
                <span class="px-2.5 py-0.5 bg-indigo-100 text-indigo-700 text-xs font-bold rounded-full uppercase tracking-wider">Vista Global</span>
            </div>
            <h1 class="text-2xl font-bold text-slate-800">Gestión de Hospitales</h1>
            <p class="text-slate-500 text-sm mt-1">Control total de todas las sedes del sistema MedSync.</p>
        </div>
        <button onclick="document.getElementById('modalHospital').classList.remove('hidden')"
                class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold px-4 py-2.5 rounded-xl transition-colors shadow-sm">
            <i data-lucide="plus" class="w-4 h-4"></i> Nueva Sede
        </button>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

        <!-- Hospital list -->
        <div class="lg:col-span-2 bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
            <div class="flex items-center justify-between mb-4">
                <h3 class="font-semibold text-slate-800 flex items-center gap-2">
                    <i data-lucide="building-2" class="w-4 h-4 text-indigo-600"></i> Sedes (@hospitales.Count)
                </h3>
                <div class="flex items-center gap-2 text-xs text-slate-400">
                    <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-green-400 inline-block"></span> @hospitales.Count(h => h.EstaActivo) activos</span>
                    <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-red-400 inline-block"></span> @hospitales.Count(h => !h.EstaActivo) inactivos</span>
                </div>
            </div>

            @if (!hospitales.Any())
            {
                <p class="text-slate-400 text-sm text-center py-6">No hay sedes registradas.</p>
            }
            else
            {
                <div class="space-y-3">
                    @foreach (var h in hospitales)
                    {
                        var statusCls = h.EstaActivo ? "bg-green-100 text-green-700" : "bg-slate-100 text-slate-500";
                        <div class="flex items-center justify-between p-4 border border-slate-100 rounded-xl hover:bg-slate-50 transition-colors">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-10 bg-indigo-50 rounded-xl flex items-center justify-center text-indigo-600">
                                    <i data-lucide="building-2" class="w-5 h-5"></i>
                                </div>
                                <div>
                                    <div class="font-medium text-slate-800">@h.Nombre</div>
                                    <div class="text-xs text-slate-400 flex items-center gap-1 mt-0.5">
                                        <i data-lucide="map-pin" class="w-3 h-3"></i>
                                        @(h.Direccion ?? "Sin dirección") • RNC: @h.Rnc
                                    </div>
                                </div>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="px-2.5 py-1 rounded-full text-xs font-semibold @statusCls">
                                    @(h.EstaActivo ? "ACTIVO" : "INACTIVO")
                                </span>
                                <button onclick="abrirEditarHospital(@h.Id, '@h.Nombre', '@h.Rnc', '@(h.Direccion ?? "")', '@(h.Telefono ?? "")', @h.EstaActivo.ToString().ToLower())"
                                        class="w-7 h-7 flex items-center justify-center hover:bg-slate-100 rounded-lg text-slate-400 hover:text-slate-600 transition-colors">
                                    <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                                </button>
                                <button onclick="verEspecialidades(@h.Id, '@h.Nombre')"
                                        class="w-7 h-7 flex items-center justify-center hover:bg-indigo-50 rounded-lg text-indigo-400 hover:text-indigo-600 transition-colors">
                                    <i data-lucide="stethoscope" class="w-3.5 h-3.5"></i>
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <!-- Specialties panel -->
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
            <h3 id="espHospitalNombre" class="font-semibold text-slate-800 mb-3 flex items-center gap-2">
                <i data-lucide="stethoscope" class="w-4 h-4 text-indigo-600"></i> Especialidades
            </h3>
            <p id="espPlaceholder" class="text-slate-400 text-sm">Selecciona una sede para ver sus especialidades.</p>
            <div id="especialidadesList" class="space-y-2 hidden"></div>
            <button id="btnAddEsp" onclick="document.getElementById('modalEspecialidad').classList.remove('hidden')"
                    class="hidden mt-3 w-full flex items-center justify-center gap-2 text-sm text-indigo-600 border border-indigo-200 hover:bg-indigo-50 px-3 py-2 rounded-xl transition-colors">
                <i data-lucide="plus" class="w-3.5 h-3.5"></i> Añadir Especialidad
            </button>
            <input type="hidden" id="selectedHospitalId" />
        </div>
    </div>
</div>

<!-- Modal: Crear Hospital -->
<div id="modalHospital" class="hidden fixed inset-0 bg-black/30 flex items-center justify-center z-50">
    <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-md mx-4">
        <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold text-slate-800">Nueva Sede</h3>
            <button onclick="document.getElementById('modalHospital').classList.add('hidden')"
                    class="w-7 h-7 rounded-lg flex items-center justify-center text-slate-400 hover:bg-slate-100 transition-colors">
                <i data-lucide="x" class="w-4 h-4"></i>
            </button>
        </div>
        <form asp-controller="SuperAdmin" asp-action="CrearHospital" method="post">
            @Html.AntiForgeryToken()
            <div class="grid grid-cols-2 gap-3 mb-3">
                <div class="col-span-2">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Nombre</label>
                    <input name="Nombre" required type="text" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">RNC</label>
                    <input name="Rnc" required type="text" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Teléfono</label>
                    <input name="Telefono" type="text" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                </div>
                <div class="col-span-2">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Dirección</label>
                    <input name="Direccion" type="text" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                </div>
            </div>
            <div class="flex gap-2 justify-end">
                <button type="button" onclick="document.getElementById('modalHospital').classList.add('hidden')" class="px-4 py-2 text-sm text-slate-500 hover:bg-slate-50 rounded-xl">Cancelar</button>
                <button type="submit" class="flex items-center gap-2 px-4 py-2 text-sm bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl font-semibold">
                    <i data-lucide="plus" class="w-3.5 h-3.5"></i> Crear
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal: Editar Hospital -->
<div id="modalEditarHospital" class="hidden fixed inset-0 bg-black/30 flex items-center justify-center z-50">
    <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-md mx-4">
        <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold text-slate-800">Editar Sede</h3>
            <button onclick="document.getElementById('modalEditarHospital').classList.add('hidden')"
                    class="w-7 h-7 rounded-lg flex items-center justify-center text-slate-400 hover:bg-slate-100 transition-colors">
                <i data-lucide="x" class="w-4 h-4"></i>
            </button>
        </div>
        <form id="formEditarHospital" asp-controller="SuperAdmin" asp-action="EditarHospital" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="edit-id" />
            <div class="grid grid-cols-2 gap-3 mb-3">
                <div class="col-span-2">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Nombre</label>
                    <input name="Nombre" id="edit-nombre" required type="text" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">RNC</label>
                    <input name="Rnc" id="edit-rnc" required type="text" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Teléfono</label>
                    <input name="Telefono" id="edit-telefono" type="text" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                </div>
                <div class="col-span-2">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Dirección</label>
                    <input name="Direccion" id="edit-direccion" type="text" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
                </div>
                <div class="col-span-2 flex items-center gap-2">
                    <input name="EstaActivo" id="edit-activo" type="checkbox" class="rounded" />
                    <label for="edit-activo" class="text-sm text-slate-600">Sede activa</label>
                </div>
            </div>
            <div class="flex gap-2 justify-end">
                <button type="button" onclick="document.getElementById('modalEditarHospital').classList.add('hidden')" class="px-4 py-2 text-sm text-slate-500 hover:bg-slate-50 rounded-xl">Cancelar</button>
                <button type="submit" class="flex items-center gap-2 px-4 py-2 text-sm bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl font-semibold">
                    <i data-lucide="save" class="w-3.5 h-3.5"></i> Guardar
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal: Crear Especialidad -->
<div id="modalEspecialidad" class="hidden fixed inset-0 bg-black/30 flex items-center justify-center z-50">
    <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-md mx-4">
        <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold text-slate-800">Nueva Especialidad</h3>
            <button onclick="document.getElementById('modalEspecialidad').classList.add('hidden')"
                    class="w-7 h-7 rounded-lg flex items-center justify-center text-slate-400 hover:bg-slate-100 transition-colors">
                <i data-lucide="x" class="w-4 h-4"></i>
            </button>
        </div>
        <form asp-controller="SuperAdmin" asp-action="CrearEspecialidad" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="HospitalId" id="esp-hospitalId" />
            <div class="mb-3">
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Nombre</label>
                <input name="Nombre" required type="text" placeholder="Ej: Cardiología"
                       class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400" />
            </div>
            <div class="mb-4">
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Descripción</label>
                <textarea name="Descripcion" rows="2"
                          class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-indigo-400 resize-none"></textarea>
            </div>
            <div class="flex gap-2 justify-end">
                <button type="button" onclick="document.getElementById('modalEspecialidad').classList.add('hidden')" class="px-4 py-2 text-sm text-slate-500 hover:bg-slate-50 rounded-xl">Cancelar</button>
                <button type="submit" class="flex items-center gap-2 px-4 py-2 text-sm bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl font-semibold">
                    <i data-lucide="plus" class="w-3.5 h-3.5"></i> Crear
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function abrirEditarHospital(id, nombre, rnc, dir, tel, activo) {
    document.getElementById('edit-id').value = id;
    document.getElementById('edit-nombre').value = nombre;
    document.getElementById('edit-rnc').value = rnc;
    document.getElementById('edit-direccion').value = dir || '';
    document.getElementById('edit-telefono').value = tel || '';
    document.getElementById('edit-activo').checked = activo;
    document.getElementById('formEditarHospital').action = `/SuperAdmin/EditarHospital?id=${id}`;
    document.getElementById('modalEditarHospital').classList.remove('hidden');
}

async function verEspecialidades(hospitalId, nombre) {
    document.getElementById('selectedHospitalId').value = hospitalId;
    document.getElementById('esp-hospitalId').value = hospitalId;
    document.getElementById('espHospitalNombre').innerHTML =
        `<i data-lucide="stethoscope" class="w-4 h-4 text-indigo-600"></i> ${nombre}`;
    document.getElementById('espPlaceholder').classList.add('hidden');
    document.getElementById('btnAddEsp').classList.remove('hidden');

    const data = await fetch(`/SuperAdmin/ObtenerEspecialidades?hospitalId=${hospitalId}`).then(r => r.json());
    const list = document.getElementById('especialidadesList');
    if (!data.length) {
        list.innerHTML = '<p class="text-slate-400 text-sm">Sin especialidades.</p>';
    } else {
        list.innerHTML = data.map(e => `
            <div class="flex items-center gap-2 py-1.5">
                <span class="w-1.5 h-1.5 rounded-full bg-indigo-400 flex-shrink-0"></span>
                <span class="text-sm text-slate-700">${e.nombre}</span>
            </div>`).join('');
    }
    list.classList.remove('hidden');
    lucide.createIcons();
}
</script>
}

@using MedSync_Frontend.Models.ViewModels
@{
    ViewData["Title"] = "Gestión de Médicos";
    var medicos = ViewBag.Medicos as List<MedicoViewModel> ?? [];
    var hospitales = ViewBag.Hospitales as List<HospitalViewModel> ?? [];
}

<div class="max-w-5xl mx-auto space-y-6">
    <div class="flex items-start justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Gestión de Médicos</h1>
            <p class="text-slate-500 text-sm mt-1">Administre el directorio de profesionales de la salud, sus especialidades y ubicaciones operativas.</p>
        </div>
        <button onclick="document.getElementById('modalMedico').classList.remove('hidden')"
                class="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2.5 rounded-xl transition-colors shadow-sm">
            <i data-lucide="plus" class="w-4 h-4"></i> Añadir Médico
        </button>
    </div>

    <!-- Stats banner -->
    <div class="bg-blue-600 text-white rounded-2xl p-5 flex items-center justify-between">
        <div>
            <p class="text-blue-200 text-sm">Vista General Mensual</p>
            <p class="text-3xl font-bold mt-1">@medicos.Count(m => m.EstaActivo) Personal Activo</p>
        </div>
        <div class="w-14 h-14 bg-white/20 rounded-2xl flex items-center justify-center">
            <i data-lucide="users" class="w-7 h-7 text-white"></i>
        </div>
    </div>

    <!-- Doctor cards -->
    @if (medicos.Any())
    {
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            @foreach (var m in medicos.Take(4))
            {
                var badgeCls = m.EstaActivo ? "bg-green-100 text-green-700" : "bg-orange-100 text-orange-700";
                var badgeTxt = m.EstaActivo ? "SALUDABLE" : "PENDIENTE";
                <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
                    <div class="flex items-start justify-between mb-3">
                        <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center text-lg font-bold text-blue-600 flex-shrink-0">
                            @m.NombreCompleto.FirstOrDefault()
                        </div>
                        <span class="px-2.5 py-1 rounded-full text-xs font-semibold @badgeCls">@badgeTxt</span>
                    </div>
                    <h3 class="font-semibold text-slate-800">@m.NombreCompleto</h3>
                    <p class="text-sm text-blue-600 font-medium">@m.NombreEspecialidad</p>
                    <p class="text-xs text-slate-400 mt-2 flex items-center gap-1.5">
                        <i data-lucide="building-2" class="w-3.5 h-3.5"></i> @m.NombreHospital
                    </p>
                    <p class="text-xs text-slate-400 mt-1 flex items-center gap-1.5">
                        <i data-lucide="hash" class="w-3.5 h-3.5"></i> Exequatur: @m.Exequatur
                    </p>
                    <div class="flex items-center justify-between mt-4">
                        <button type="button"
                            onclick="abrirHospitalesMedico(@m.Id, '@m.NombreCompleto.Replace("'", "\\'")')"
                                class="text-xs text-blue-600 hover:underline font-medium">
                            Hospitales
                        </button>
                        <div class="flex items-center gap-2">
                                <button type="button"
                                    onclick="abrirHospitalesMedico(@m.Id, '@m.NombreCompleto.Replace("'", "\\'")')"
                                    class="text-xs text-slate-500 border border-slate-200 hover:bg-slate-50 px-3 py-1.5 rounded-xl transition-colors">
                                Editar hospitales
                            </button>
                            <form asp-controller="Admin" asp-action="ToggleMedico" method="post" class="inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@m.Id" />
                                <input type="hidden" name="estaActivo" value="@(!m.EstaActivo)" />
                                <button type="submit" class="text-xs text-slate-500 border border-slate-200 hover:bg-slate-50 px-3 py-1.5 rounded-xl transition-colors">
                                    @(m.EstaActivo ? "Desactivar" : "Activar")
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Detailed list -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
            <h3 class="font-semibold text-slate-800">Listado Detallado</h3>
            <span class="text-sm text-slate-400">Mostrando @medicos.Count médicos</span>
        </div>
        @if (!medicos.Any())
        {
            <div class="text-center py-10 text-slate-400">
                <div class="flex justify-center mb-3">
                    <div class="w-12 h-12 bg-slate-50 rounded-2xl flex items-center justify-center">
                        <i data-lucide="stethoscope" class="w-6 h-6 text-slate-300"></i>
                    </div>
                </div>
                <p class="text-sm">No hay médicos registrados.</p>
            </div>
        }
        else
        {
            <table class="w-full text-sm">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Médico</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Especialidad</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Ubicación</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Estado</th>
                        <th class="px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var m in medicos)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-5 py-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-7 h-7 bg-blue-100 rounded-full flex items-center justify-center text-xs font-bold text-blue-600 flex-shrink-0">
                                        @m.NombreCompleto.FirstOrDefault()
                                    </div>
                                    <span class="font-medium text-slate-700">@m.NombreCompleto</span>
                                </div>
                            </td>
                            <td class="px-5 py-3 text-slate-500">@m.NombreEspecialidad</td>
                            <td class="px-5 py-3 text-slate-500">@m.NombreHospital</td>
                            <td class="px-5 py-3">
                                <span class="px-2.5 py-1 rounded-full text-xs font-medium @(m.EstaActivo ? "bg-green-100 text-green-700" : "bg-red-100 text-red-600")">
                                    @(m.EstaActivo ? "ACTIVO" : "INACTIVO")
                                </span>
                            </td>
                            <td class="px-5 py-3 text-right">
                                <div class="flex items-center justify-end gap-3">
                                        <button type="button"
                                            onclick="abrirHospitalesMedico(@m.Id, '@m.NombreCompleto.Replace("'", "\\'")')"
                                            class="inline-flex items-center gap-1.5 text-xs text-slate-600 hover:underline">
                                        <i data-lucide="building-2" class="w-3.5 h-3.5"></i>
                                        Hospitales
                                    </button>
                                    <form asp-controller="Admin" asp-action="ToggleMedico" method="post" class="inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@m.Id" />
                                        <input type="hidden" name="estaActivo" value="@(!m.EstaActivo)" />
                                        <button type="submit" class="inline-flex items-center gap-1.5 text-xs text-blue-600 hover:underline">
                                            <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                                            @(m.EstaActivo ? "Desactivar" : "Activar")
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- Modal: Editar Hospitales del Médico -->
<div id="modalHospitalesMedico" class="hidden fixed inset-0 bg-black/30 flex items-center justify-center z-50 overflow-y-auto py-6">
    <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-lg mx-4">
        <div class="flex items-center justify-between mb-4">
            <div>
                <h3 class="font-semibold text-slate-800">Hospitales del médico</h3>
                <p id="hospitales-medico-nombre" class="text-xs text-slate-400 mt-0.5"></p>
            </div>
            <button onclick="document.getElementById('modalHospitalesMedico').classList.add('hidden')"
                    class="w-7 h-7 rounded-lg flex items-center justify-center text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition-colors">
                <i data-lucide="x" class="w-4 h-4"></i>
            </button>
        </div>

        <form asp-controller="Admin" asp-action="ActualizarHospitalesMedico" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="medicoId" id="hospitales-medico-id" />

            <div class="border border-slate-100 rounded-xl p-3 max-h-72 overflow-y-auto space-y-2" id="hospitales-medico-checks">
                @foreach (var h in hospitales)
                {
                    <label class="flex items-center gap-2 text-sm text-slate-700">
                        <input type="checkbox" name="hospitalesIds" value="@h.Id" class="rounded border-slate-300 text-blue-600 focus:ring-blue-400" />
                        @h.Nombre
                    </label>
                }
            </div>

            <p class="text-xs text-slate-400 mt-3">Selecciona uno o varios hospitales para este médico.</p>

            <div class="flex gap-2 justify-end mt-4">
                <button type="button" onclick="document.getElementById('modalHospitalesMedico').classList.add('hidden')"
                        class="px-4 py-2 text-sm text-slate-500 hover:bg-slate-50 rounded-xl">Cancelar</button>
                <button type="submit" class="flex items-center gap-2 px-4 py-2 text-sm bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-semibold">
                    <i data-lucide="save" class="w-4 h-4"></i> Guardar hospitales
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal: Crear Médico -->
<div id="modalMedico" class="hidden fixed inset-0 bg-black/30 flex items-center justify-center z-50 overflow-y-auto py-6">
    <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-lg mx-4">
        <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold text-slate-800">Registrar Médico</h3>
            <button onclick="document.getElementById('modalMedico').classList.add('hidden')"
                    class="w-7 h-7 rounded-lg flex items-center justify-center text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition-colors">
                <i data-lucide="x" class="w-4 h-4"></i>
            </button>
        </div>
        <form asp-controller="Admin" asp-action="CrearMedico" method="post">
            @Html.AntiForgeryToken()
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">Datos del médico</p>
            <div class="grid grid-cols-2 gap-3 mb-4">
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Nombre</label>
                    <input name="Nombre" required type="text" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Apellido</label>
                    <input name="Apellido" required type="text" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Exequatur (Licencia)</label>
                    <input name="Exequatur" required type="text" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Hospital</label>
                    <select name="HospitalId" id="modal-hospitalId" required onchange="cargarEspecialidadesModal(this.value)"
                            class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400">
                        <option value="">Seleccionar...</option>
                        @foreach (var h in hospitales)
                        {
                            <option value="@h.Id">@h.Nombre</option>
                        }
                    </select>
                </div>
                <div class="col-span-2">
                    <label class="block text-xs text-slate-500 mb-1">Especialidad</label>
                    <select name="EspecialidadId" id="modal-especialidadId" required
                            class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400">
                        <option value="">Seleccionar hospital primero...</option>
                    </select>
                </div>
            </div>

            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">Cuenta de acceso</p>
            <div class="grid grid-cols-2 gap-3 mb-4">
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Email</label>
                    <input name="Email" required type="email" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Contraseña (mín. 8)</label>
                    <input name="Contrasena" required type="password" minlength="8"
                           class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Nombre (cuenta)</label>
                    <input name="Nombre" type="text" required class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Apellido (cuenta)</label>
                    <input name="Apellido" type="text" required class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
            </div>

            <div class="flex gap-2 justify-end">
                <button type="button" onclick="document.getElementById('modalMedico').classList.add('hidden')"
                        class="px-4 py-2 text-sm text-slate-500 hover:bg-slate-50 rounded-xl">Cancelar</button>
                <button type="submit" class="flex items-center gap-2 px-4 py-2 text-sm bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-semibold">
                    <i data-lucide="user-plus" class="w-4 h-4"></i> Registrar
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
async function cargarEspecialidadesModal(hospitalId) {
    const sel = document.getElementById('modal-especialidadId');
    sel.innerHTML = '<option value="">Cargando...</option>';
    if (!hospitalId) return;
    const data = await fetch(`/Admin/ObtenerEspecialidades?hospitalId=${hospitalId}`).then(r => r.json());
    sel.innerHTML = '<option value="">Seleccionar...</option>' + data.map(e => `<option value="${e.id}">${e.nombre}</option>`).join('');
}

async function abrirHospitalesMedico(medicoId, nombreMedico) {
    document.getElementById('hospitales-medico-id').value = medicoId;
    document.getElementById('hospitales-medico-nombre').textContent = nombreMedico;

    const checks = document.querySelectorAll('#hospitales-medico-checks input[type="checkbox"]');
    checks.forEach(c => c.checked = false);

    try {
        const asignados = await fetch(`/Admin/ObtenerHospitalesAsignadosMedico?medicoId=${medicoId}`).then(r => r.json());
        const asignadosIds = new Set(asignados.map(h => h.hospitalId));
        checks.forEach(c => {
            c.checked = asignadosIds.has(parseInt(c.value));
        });
    } catch {
        // Si falla la carga, deja los checks sin seleccionar.
    }

    document.getElementById('modalHospitalesMedico').classList.remove('hidden');
}
</script>
}

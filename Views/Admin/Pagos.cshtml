@using MedSync_Frontend.Models.ViewModels
@{
    ViewData["Title"] = "Pagos";
    var pagos = ViewBag.Pagos as List<PagoViewModel> ?? [];
    var hospitales = ViewBag.Hospitales as List<HospitalViewModel> ?? [];
    var total = pagos.Where(p => p.Estado == "Completed").Sum(p => p.Monto);
}

<div class="max-w-5xl mx-auto space-y-6">
    <div class="flex items-start justify-between">
        <div>
            <h1 class="text-2xl font-bold text-slate-800">Pagos</h1>
            <p class="text-slate-500 text-sm mt-1">Registro de pagos por consulta.</p>
        </div>
        <button onclick="document.getElementById('modalPago').classList.remove('hidden')"
                class="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2.5 rounded-xl transition-colors shadow-sm">
            <i data-lucide="plus" class="w-4 h-4"></i> Registrar Pago
        </button>
    </div>

    <!-- Summary -->
    <div class="grid grid-cols-3 gap-4">
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
            <p class="text-xs text-slate-400 uppercase font-semibold">Total Completado</p>
            <p class="text-2xl font-bold text-green-600 mt-1">$@total.ToString("N2")</p>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
            <p class="text-xs text-slate-400 uppercase font-semibold">Total Pagos</p>
            <p class="text-2xl font-bold text-slate-800 mt-1">@pagos.Count</p>
        </div>
        <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
            <p class="text-xs text-slate-400 uppercase font-semibold">Pendientes</p>
            <p class="text-2xl font-bold text-yellow-600 mt-1">@pagos.Count(p => p.Estado == "Pending")</p>
        </div>
    </div>

    <!-- Table -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
        @if (!pagos.Any())
        {
            <div class="text-center py-16">
                <div class="flex justify-center mb-3">
                    <div class="w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center">
                        <i data-lucide="credit-card" class="w-7 h-7 text-slate-300"></i>
                    </div>
                </div>
                <p class="text-slate-500">No hay pagos registrados.</p>
            </div>
        }
        else
        {
            <table class="w-full text-sm">
                <thead class="bg-slate-50 border-b border-slate-100">
                    <tr>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Cita #</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Monto</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Método</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Estado</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Fecha</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var p in pagos)
                    {
                        var estadoCls = p.Estado == "Completed" ? "bg-green-100 text-green-700" :
                                        p.Estado == "Pending" ? "bg-yellow-100 text-yellow-700" :
                                        "bg-blue-100 text-blue-700";
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-5 py-3 text-slate-500">#@p.CitaId</td>
                            <td class="px-5 py-3 font-semibold text-slate-800">$@p.Monto.ToString("N2")</td>
                            <td class="px-5 py-3 text-slate-500">@p.MetodoPago</td>
                            <td class="px-5 py-3">
                                <span class="px-2.5 py-1 rounded-full text-xs font-medium @estadoCls">@p.Estado</span>
                            </td>
                            <td class="px-5 py-3 text-slate-400">@p.FechaPago.ToString("dd MMM yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<!-- Modal: Registrar Pago -->
<div id="modalPago" class="hidden fixed inset-0 bg-black/30 flex items-center justify-center z-50">
    <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-md mx-4">
        <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold text-slate-800">Registrar Pago</h3>
            <button onclick="document.getElementById('modalPago').classList.add('hidden')"
                    class="w-7 h-7 rounded-lg flex items-center justify-center text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition-colors">
                <i data-lucide="x" class="w-4 h-4"></i>
            </button>
        </div>
        <form asp-controller="Admin" asp-action="RegistrarPago" method="post">
            @Html.AntiForgeryToken()
            <div class="space-y-3 mb-4">
                <div>
                    <label class="block text-xs text-slate-500 mb-1">ID de la Cita</label>
                    <input name="CitaId" required type="number" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Monto</label>
                    <input name="Monto" required type="number" step="0.01" min="0.01"
                           class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Método de Pago</label>
                    <select name="MetodoPago" required class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400">
                        <option value="Cash">Efectivo</option>
                        <option value="Card">Tarjeta</option>
                        <option value="Insurance">Seguro</option>
                    </select>
                </div>
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Estado</label>
                    <select name="Estado" required class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400">
                        <option value="Completed">Completado</option>
                        <option value="Pending">Pendiente</option>
                    </select>
                </div>
            </div>
            <div class="flex gap-2 justify-end">
                <button type="button" onclick="document.getElementById('modalPago').classList.add('hidden')"
                        class="px-4 py-2 text-sm text-slate-500 hover:bg-slate-50 rounded-xl">Cancelar</button>
                <button type="submit" class="px-4 py-2 text-sm bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-semibold">Guardar</button>
            </div>
        </form>
    </div>
</div>

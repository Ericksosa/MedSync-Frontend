@{
    ViewData["Title"] = "Registrar Paciente";
}

<div class="max-w-2xl mx-auto">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-slate-800">Registrar Nuevo Paciente</h1>
        <p class="text-slate-500 text-sm mt-1">Complete los datos del paciente y cree su cuenta de acceso.</p>
    </div>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
        <form asp-controller="Admin" asp-action="RegistrarPaciente" method="post">
            @Html.AntiForgeryToken()

            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-4">Datos Personales</p>
            <div class="grid grid-cols-2 gap-4 mb-4">
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Nombre</label>
                    <input name="Nombre" required type="text" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Apellido</label>
                    <input name="Apellido" required type="text" class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Documento de Identidad</label>
                    <input name="DocumentoId" required type="text" placeholder="Cédula o pasaporte"
                           class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Fecha de Nacimiento</label>
                    <input name="FechaNacimiento" required type="date"
                           class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Email</label>
                    <input name="Email" type="email"
                           class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Teléfono</label>
                    <input name="Telefono" type="text"
                           class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
            </div>

            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-4 pt-2 border-t border-slate-100">Cuenta de Acceso</p>
            <div class="grid grid-cols-2 gap-4 mb-6">
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Email de la cuenta</label>
                    <input name="emailCuenta" required type="email"
                           class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
                <div>
                    <label class="block text-xs text-slate-500 mb-1">Contraseña (mín. 8 caracteres)</label>
                    <input name="passwordCuenta" required type="password" minlength="8"
                           class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
                </div>
            </div>

            <div class="flex gap-3 justify-end">
                <a href="/Admin/Dashboard" class="px-4 py-2.5 text-sm text-slate-500 hover:bg-slate-50 rounded-xl">Cancelar</a>
                <button type="submit" class="flex items-center gap-2 px-6 py-2.5 text-sm bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-semibold transition-colors shadow-sm">
                    <i data-lucide="user-plus" class="w-4 h-4"></i> Registrar Paciente
                </button>
            </div>
        </form>
    </div>
</div>

@model MedSync_Frontend.Models.ViewModels.PacienteRegistroViewModel
@{
    Layout = null;
    ViewData["Title"] = "Registro de Paciente";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MedSync — Registro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: { extend: { fontFamily: { sans: ['Inter', 'sans-serif'] } } }
        }
    </script>
</head>
<body class="min-h-screen bg-gradient-to-br from-blue-50 to-slate-100 flex items-center justify-center px-4 py-8 font-sans">

<div class="w-full max-w-lg">
    <!-- Logo -->
    <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-blue-600 text-white mb-3 shadow-lg">
            <i data-lucide="cross" class="w-7 h-7"></i>
        </div>
        <h1 class="text-2xl font-bold text-blue-700 tracking-wide">MedSync</h1>
        <p class="text-xs text-slate-500 uppercase tracking-widest mt-1">Tu Salud Conectada</p>
    </div>

    <!-- Card -->
    <div class="bg-white rounded-2xl shadow-lg p-8">
        <h2 class="text-xl font-semibold text-slate-800 mb-1">Crear cuenta de paciente</h2>
        <p class="text-sm text-slate-500 mb-6">Completa tu información para registrarte en MedSync.</p>

        @if (TempData["Error"] is string err)
        {
            <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700 flex items-center gap-2">
                <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i> @err
            </div>
        }

        <form asp-action="Registro" asp-controller="Auth" method="post">
            @Html.AntiForgeryToken()

            <!-- Datos personales -->
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Datos personales</p>

            <div class="grid grid-cols-2 gap-3 mb-3">
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Nombre</label>
                    <input asp-for="Nombre" type="text" placeholder="Juan"
                           class="w-full px-3 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 transition-shadow" />
                    <span asp-validation-for="Nombre" class="text-xs text-red-600 mt-0.5 block"></span>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Apellido</label>
                    <input asp-for="Apellido" type="text" placeholder="Pérez"
                           class="w-full px-3 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 transition-shadow" />
                    <span asp-validation-for="Apellido" class="text-xs text-red-600 mt-0.5 block"></span>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-3 mb-3">
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Documento de Identidad</label>
                    <input asp-for="DocumentoId" type="text" placeholder="001-0000000-0"
                           class="w-full px-3 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 transition-shadow" />
                    <span asp-validation-for="DocumentoId" class="text-xs text-red-600 mt-0.5 block"></span>
                </div>
                <div>
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Teléfono</label>
                    <input asp-for="Telefono" type="tel" placeholder="809-000-0000"
                           class="w-full px-3 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 transition-shadow" />
                </div>
            </div>

            <div class="mb-5">
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Fecha de Nacimiento</label>
                <input asp-for="FechaNacimiento" type="date"
                       class="w-full px-3 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 transition-shadow" />
                <span asp-validation-for="FechaNacimiento" class="text-xs text-red-600 mt-0.5 block"></span>
            </div>

            <!-- Cuenta de acceso -->
            <p class="text-xs font-semibold text-slate-400 uppercase tracking-wider mb-3">Cuenta de acceso</p>

            <div class="mb-3">
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Email</label>
                <div class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">
                        <i data-lucide="at-sign" class="w-4 h-4"></i>
                    </span>
                    <input asp-for="Email" type="email" placeholder="juan@correo.com"
                           class="w-full pl-9 pr-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 transition-shadow" />
                </div>
                <span asp-validation-for="Email" class="text-xs text-red-600 mt-0.5 block"></span>
            </div>

            <div class="mb-6">
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1.5">Contraseña</label>
                <div class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">
                        <i data-lucide="lock-keyhole" class="w-4 h-4"></i>
                    </span>
                    <input asp-for="Contrasena" id="passwordInput" type="password" placeholder="Mínimo 8 caracteres"
                           class="w-full pl-9 pr-10 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 transition-shadow" />
                    <button type="button" onclick="togglePassword()"
                            class="absolute right-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 transition-colors">
                        <i data-lucide="eye" id="eyeIcon" class="w-4 h-4"></i>
                    </button>
                </div>
                <span asp-validation-for="Contrasena" class="text-xs text-red-600 mt-0.5 block"></span>
            </div>

            <div asp-validation-summary="ModelOnly" class="mb-4 text-sm text-red-600"></div>

            <button type="submit"
                    class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-xl transition-colors flex items-center justify-center gap-2 shadow-sm">
                Crear cuenta
                <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </button>
        </form>

        <p class="text-center text-xs text-slate-400 mt-6">
            ¿Ya tienes cuenta? <a href="/Auth/Login" class="text-blue-600 font-medium hover:underline">Inicia sesión</a>
        </p>
    </div>
</div>

<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
<script>
    lucide.createIcons();
    function togglePassword() {
        const input = document.getElementById('passwordInput');
        const icon = document.getElementById('eyeIcon');
        if (input.type === 'password') {
            input.type = 'text';
            icon.setAttribute('data-lucide', 'eye-off');
        } else {
            input.type = 'password';
            icon.setAttribute('data-lucide', 'eye');
        }
        lucide.createIcons();
    }
</script>
</body>
</html>

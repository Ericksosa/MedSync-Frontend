@{
    Layout = null;
    ViewData["Title"] = "Recuperar Contraseña";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>MedSync — Recuperar Contraseña</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: { extend: { fontFamily: { sans: ['Inter', 'sans-serif'] } } }
        }
    </script>
</head>
<body class="min-h-screen bg-gradient-to-br from-blue-50 to-slate-100 flex items-center justify-center px-4 font-sans">

<div class="w-full max-w-md">
    <!-- Logo -->
    <div class="text-center mb-8">
        <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-blue-600 text-white mb-3 shadow-lg">
            <i data-lucide="cross" class="w-7 h-7"></i>
        </div>
        <h1 class="text-2xl font-bold text-blue-700 tracking-wide">MedSync</h1>
        <p class="text-xs text-slate-500 uppercase tracking-widest mt-1">Tu Salud Conectada</p>
    </div>

    <!-- Card -->
    <div class="bg-white rounded-2xl shadow-lg p-8 text-center">
        <div class="w-16 h-16 bg-blue-50 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <i data-lucide="lock-keyhole" class="w-8 h-8 text-blue-500"></i>
        </div>

        <h2 class="text-xl font-semibold text-slate-800 mb-2">Recuperación de contraseña</h2>
        <p class="text-sm text-slate-500 mb-6 leading-relaxed">
            La recuperación de contraseñas por correo electrónico no está disponible en este momento.
        </p>

        <div class="bg-blue-50 border border-blue-100 rounded-xl p-4 mb-6 text-left">
            <div class="flex items-start gap-3">
                <i data-lucide="info" class="w-5 h-5 text-blue-500 flex-shrink-0 mt-0.5"></i>
                <div>
                    <p class="text-sm font-semibold text-blue-800 mb-1">¿Cómo recuperar tu acceso?</p>
                    <p class="text-xs text-blue-700 leading-relaxed">
                        Contacta al administrador de tu hospital o al soporte técnico de MedSync para que restablezcan tu contraseña manualmente.
                    </p>
                </div>
            </div>
        </div>

        <div class="bg-slate-50 rounded-xl p-4 mb-6 text-left space-y-2">
            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider">Contacto de soporte</p>
            <div class="flex items-center gap-2 text-sm text-slate-600">
                <i data-lucide="mail" class="w-4 h-4 text-slate-400"></i>
                soporte@medsync.com
            </div>
            <div class="flex items-center gap-2 text-sm text-slate-600">
                <i data-lucide="phone" class="w-4 h-4 text-slate-400"></i>
                809-000-0000
            </div>
        </div>

        <a href="/Auth/Login"
           class="block w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-xl transition-colors text-center text-sm">
            Volver al inicio de sesión
        </a>
    </div>
</div>

<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
<script>lucide.createIcons();</script>
</body>
</html>

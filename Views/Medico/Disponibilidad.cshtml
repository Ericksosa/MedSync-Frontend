@using MedSync_Frontend.Models.ViewModels
@{
    ViewData["Title"] = "Mi Disponibilidad";
    var hospitalesAsignados = ViewBag.HospitalesAsignados as List<HospitalAsignadoViewModel> ?? [];
    var disponibilidades = ViewBag.Disponibilidades as List<DisponibilidadViewModel> ?? [];
    var hospitalIdSeleccionado = ViewBag.HospitalIdSeleccionado is int hId ? hId : 0;
    var nombreHospital = ViewBag.NombreHospitalSeleccionado as string ?? "Hospital";

    var dias = new Dictionary<int, string>
    {
        [0] = "Lunes",
        [1] = "Martes",
        [2] = "Miercoles",
        [3] = "Jueves",
        [4] = "Viernes",
        [5] = "Sabado",
        [6] = "Domingo"
    };
}

<div class="max-w-5xl mx-auto space-y-6">
    <div class="flex items-start justify-between gap-3 flex-wrap">
        <div>
            <p class="text-xs text-blue-600 font-semibold uppercase tracking-wider">Configuracion de agenda</p>
            <h1 class="text-2xl font-bold text-slate-800">Dias de trabajo por hospital</h1>
            <p class="text-sm text-slate-500 mt-1">Selecciona el hospital y define los dias/horarios en que atenderas.</p>
        </div>
    </div>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5 space-y-4">
        <form method="get" asp-action="Disponibilidad" class="flex items-end gap-3 flex-wrap">
            <div>
                <label class="text-sm font-medium text-slate-600 block mb-1">Hospital</label>
                <select name="hospitalId" class="rounded-xl border-slate-200 text-sm min-w-72" onchange="this.form.submit()">
                    @foreach (var hospital in hospitalesAsignados)
                    {
                        if (hospital.HospitalId == hospitalIdSeleccionado)
                        {
                            <option value="@hospital.HospitalId" selected>@hospital.NombreHospital</option>
                        }
                        else
                        {
                            <option value="@hospital.HospitalId">@hospital.NombreHospital</option>
                        }
                    }
                </select>
            </div>
        </form>

        @if (!hospitalesAsignados.Any())
        {
            <div class="p-4 rounded-xl bg-amber-50 border border-amber-200 text-sm text-amber-700">
                No tienes hospitales asignados.
            </div>
        }
        else
        {
            <div class="p-4 rounded-xl bg-blue-50 border border-blue-100 text-sm text-blue-700">
                Configurando disponibilidad para: <span class="font-semibold">@nombreHospital</span>
            </div>

            <form asp-action="AgregarDisponibilidad" method="post" class="grid grid-cols-1 md:grid-cols-4 gap-3">
                @Html.AntiForgeryToken()
                <input type="hidden" name="hospitalId" value="@hospitalIdSeleccionado" />

                <div>
                    <label class="text-sm font-medium text-slate-600 block mb-1">Dia</label>
                    <select name="diaSemana" class="w-full rounded-xl border-slate-200 text-sm" required>
                        @foreach (var item in dias)
                        {
                            <option value="@item.Key">@item.Value</option>
                        }
                    </select>
                </div>

                <div>
                    <label class="text-sm font-medium text-slate-600 block mb-1">Hora inicio</label>
                    <input type="time" name="horaInicio" class="w-full rounded-xl border-slate-200 text-sm" required />
                </div>

                <div>
                    <label class="text-sm font-medium text-slate-600 block mb-1">Hora fin</label>
                    <input type="time" name="horaFin" class="w-full rounded-xl border-slate-200 text-sm" required />
                </div>

                <div class="flex items-end">
                    <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white text-sm font-semibold px-4 py-2.5 rounded-xl transition-colors">
                        Agregar horario
                    </button>
                </div>
            </form>
        }
    </div>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
        <div class="px-5 py-4 border-b border-slate-100 flex items-center justify-between">
            <h2 class="font-semibold text-slate-800">Horarios configurados</h2>
            <span class="text-xs text-slate-400">@disponibilidades.Count registro(s)</span>
        </div>

        @if (!disponibilidades.Any())
        {
            <div class="text-center py-12 text-slate-400 text-sm">No hay horarios registrados para este hospital.</div>
        }
        else
        {
            <table class="w-full text-sm">
                <thead class="bg-slate-50 border-b border-slate-100">
                    <tr>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Hospital</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Dia</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Inicio</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Fin</th>
                        <th class="px-5 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var d in disponibilidades)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-5 py-3 text-slate-600">@(string.IsNullOrWhiteSpace(d.NombreHospital) ? nombreHospital : d.NombreHospital)</td>
                            <td class="px-5 py-3 font-medium text-slate-700">@d.NombreDia</td>
                            <td class="px-5 py-3 text-slate-600">@d.HoraInicio</td>
                            <td class="px-5 py-3 text-slate-600">@d.HoraFin</td>
                            <td class="px-5 py-3 text-right">
                                <form asp-action="EliminarDisponibilidad" method="post" class="inline"
                                      onsubmit="return confirm('Eliminar este horario?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="disponibilidadId" value="@d.Id" />
                                    <input type="hidden" name="hospitalId" value="@hospitalIdSeleccionado" />
                                    <button type="submit" class="text-xs text-red-600 hover:text-red-700 font-semibold">Eliminar</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

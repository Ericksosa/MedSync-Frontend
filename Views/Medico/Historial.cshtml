@using MedSync_Frontend.Models.ViewModels
@{
    ViewData["Title"] = "Historial";
    var citas = ViewBag.Citas as List<CitaViewModel> ?? [];
}

<div class="max-w-4xl mx-auto">
    <div class="mb-6">
        <h1 class="text-2xl font-bold text-slate-800">Historial de Citas</h1>
        <p class="text-slate-500 text-sm mt-1">Citas del día de hoy.</p>
    </div>

    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm overflow-hidden">
        @if (!citas.Any())
        {
            <div class="text-center py-16">
                <div class="flex justify-center mb-3">
                    <div class="w-14 h-14 bg-slate-50 rounded-2xl flex items-center justify-center">
                        <i data-lucide="clock" class="w-7 h-7 text-slate-300"></i>
                    </div>
                </div>
                <p class="text-slate-500">Sin citas para mostrar.</p>
            </div>
        }
        else
        {
            <table class="w-full text-sm">
                <thead class="bg-slate-50 border-b border-slate-100">
                    <tr>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Paciente</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Hospital</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Fecha</th>
                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Estado</th>
                        <th class="px-5 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var cita in citas)
                    {
                        <tr class="hover:bg-slate-50 transition-colors">
                            <td class="px-5 py-3">
                                <a href="/Medico/Paciente/@cita.PacienteId" class="font-medium text-blue-600 hover:underline">
                                    @cita.NombrePaciente
                                </a>
                            </td>
                            <td class="px-5 py-3 text-slate-500">@cita.NombreHospital</td>
                            <td class="px-5 py-3 text-slate-600">@cita.FechaHora.ToString("dd MMM yyyy • HH:mm")</td>
                            <td class="px-5 py-3">
                                <span class="px-2.5 py-1 rounded-full text-xs font-medium @cita.EstadoBadgeClass">@cita.Estado</span>
                            </td>
                                <td class="px-5 py-3 flex items-center gap-2 flex-wrap">
                                <a href="/Medico/Paciente/@cita.PacienteId" class="text-xs text-blue-600 hover:underline">Ver expediente</a>
                                @if (cita.Estado == "Pendiente" || cita.Estado == "Confirmada")
                                {
                                    <form asp-controller="Medico" asp-action="CambiarEstado" method="post" class="inline"
                                          onsubmit="return confirm('¿Cancelar esta cita?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="citaId" value="@cita.Id" />
                                        <input type="hidden" name="estado" value="Cancelada" />
                                        <input type="hidden" name="returnUrl" value="/Medico/Historial" />
                                        <button type="submit"
                                                class="text-xs text-red-500 hover:text-red-700 font-medium border border-red-200 hover:bg-red-50 px-2 py-1 rounded-lg transition-colors">
                                            Cancelar
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@using MedSync_Frontend.Models.ViewModels
@{
    ViewData["Title"] = "Expediente del Paciente";
    var expediente = ViewBag.Expediente as ExpedienteViewModel;
    var paciente = ViewBag.Paciente as PacienteViewModel;
    var medicoId = ViewBag.MedicoId as int?;
}

<div class="max-w-4xl mx-auto space-y-6">

    <!-- Patient header -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
        <div class="flex items-start gap-5">
            <div class="w-16 h-16 rounded-2xl bg-blue-100 flex items-center justify-center text-2xl font-bold text-blue-600 flex-shrink-0">
                @(paciente?.Nombre.FirstOrDefault().ToString().ToUpper() ?? "?")
            </div>
            <div class="flex-1">
                <div class="flex items-center gap-3 flex-wrap">
                    <span class="text-xs text-blue-600 font-semibold uppercase tracking-wider">Record Médico #MR-@expediente?.Id</span>
                    <span class="px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Activo</span>
                </div>
                <div class="flex items-center gap-2 mt-1">
                    <h1 class="text-xl font-bold text-slate-800">@paciente?.NombreCompleto</h1>
                    <button class="w-7 h-7 rounded-lg flex items-center justify-center text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition-colors">
                        <i data-lucide="pencil" class="w-3.5 h-3.5"></i>
                    </button>
                </div>
                <div class="flex flex-wrap gap-6 mt-2 text-sm text-slate-500">
                    <span>Edad: <strong class="text-slate-700">@(paciente?.Edad is int edad ? $"{edad} años" : "No definida")</strong></span>
                    <span>Doc: <strong class="text-slate-700">@paciente?.DocumentoId</strong></span>
                    @if (paciente?.Email != null) { <span>Email: <strong class="text-slate-700">@paciente.Email</strong></span> }
                    @if (paciente?.Telefono != null) { <span>Tel: <strong class="text-slate-700">@paciente.Telefono</strong></span> }
                </div>

                <form asp-controller="Medico" asp-action="ActualizarFechaNacimientoPaciente" method="post" class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="pacienteId" value="@paciente?.Id" />
                    <input type="hidden" name="nombre" value="@paciente?.Nombre" />
                    <input type="hidden" name="apellido" value="@paciente?.Apellido" />
                    <input type="hidden" name="email" value="@paciente?.Email" />
                    <input type="hidden" name="telefono" value="@paciente?.Telefono" />

                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Fecha de nacimiento</label>
                        <input type="date" name="fechaNacimiento"
                               value="@(paciente is null || paciente.FechaNacimiento == default ? string.Empty : paciente.FechaNacimiento.ToString("yyyy-MM-dd"))"
                               max="@DateTime.Today.ToString("yyyy-MM-dd")"
                               required
                               class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm bg-white text-slate-700 focus:outline-none focus:ring-2 focus:ring-blue-400" />
                    </div>
                    <div>
                        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Edad del paciente</label>
                        <div class="flex items-center gap-2">
                            <input type="text" readonly
                                   value="@(paciente?.Edad is int edadInput ? $"{edadInput} años" : "No definida")"
                                   class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm bg-slate-50 text-slate-700" />
                            <button type="submit"
                                    class="px-3 py-2 text-xs font-semibold text-blue-600 border border-blue-200 rounded-xl hover:bg-blue-50 transition-colors whitespace-nowrap">
                                Guardar
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <form asp-controller="Medico" asp-action="ActualizarSignosVitales" method="post" class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5">
        @Html.AntiForgeryToken()
        <input type="hidden" name="expedienteId" value="@expediente?.Id" />
        <input type="hidden" name="pacienteId" value="@paciente?.Id" />

        <div class="flex items-center justify-between mb-4">
            <h2 class="font-semibold text-slate-800 flex items-center gap-2">
                <i data-lucide="activity" class="w-4 h-4 text-blue-600"></i> Signos vitales
            </h2>
            <button type="submit"
                    class="px-4 py-2 text-sm bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-semibold transition-colors">
                Guardar signos
            </button>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Ritmo cardiaco (BPM)</label>
                <input name="ritmoCardiaco" type="number" min="20" max="250"
                       value="@(expediente?.RitmoCardiaco?.ToString() ?? string.Empty)"
                       class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Temperatura (°C)</label>
                <input name="temperatura" type="number" min="30" max="45" step="0.1"
                       value="@(expediente?.Temperatura?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty)"
                       class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
            </div>
            <div>
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Presión arterial</label>
                <input name="presionArterial" type="text" maxlength="20" placeholder="Ej: 120/80"
                       value="@(expediente?.PresionArterial ?? string.Empty)"
                       class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
            </div>
        </div>
    </form>

    <!-- Diagnósticos -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
            <h2 class="font-semibold text-slate-800 flex items-center gap-2">
                <i data-lucide="stethoscope" class="w-4 h-4 text-blue-600"></i> Diagnósticos e Historial
            </h2>
            <button onclick="document.getElementById('modalDiagnostico').classList.remove('hidden')"
                    class="flex items-center gap-1.5 text-sm text-blue-600 border border-blue-200 hover:bg-blue-50 px-3 py-1.5 rounded-xl transition-colors">
                <i data-lucide="plus" class="w-3.5 h-3.5"></i> Nueva entrada
            </button>
        </div>

        @if (expediente?.Diagnosticos?.Any() != true)
        {
            <p class="text-slate-400 text-sm">Sin diagnósticos registrados.</p>
        }
        else
        {
            <div class="space-y-3">
                @foreach (var d in expediente.Diagnosticos.OrderByDescending(x => x.FechaRegistro))
                {
                    <div class="border border-slate-100 rounded-xl p-4 hover:bg-slate-50 transition-colors">
                        <div class="flex items-start justify-between">
                            <div class="flex-1">
                                <p class="text-sm font-medium text-slate-800">@d.Descripcion</p>
                                <p class="text-xs text-slate-400 mt-1 flex items-center gap-1.5">
                                    <i data-lucide="user" class="w-3 h-3"></i>
                                    @d.NombreMedico • @d.FechaRegistro.ToString("dd MMM yyyy")
                                </p>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>

    <!-- Recetas -->
    <div class="bg-white rounded-2xl border border-slate-100 shadow-sm p-6">
        <div class="flex items-center justify-between mb-4">
            <h2 class="font-semibold text-slate-800 flex items-center gap-2">
                <i data-lucide="clipboard" class="w-4 h-4 text-blue-600"></i> Recetas actuales
            </h2>
            <button onclick="document.getElementById('modalReceta').classList.remove('hidden')"
                    class="flex items-center gap-1.5 text-sm bg-blue-600 hover:bg-blue-700 text-white px-4 py-1.5 rounded-xl transition-colors">
                <i data-lucide="file-plus-2" class="w-3.5 h-3.5"></i> Emitir receta
            </button>
        </div>

        @if (expediente?.Recetas?.Any() != true)
        {
            <p class="text-slate-400 text-sm">Sin recetas emitidas.</p>
        }
        else
        {
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                @foreach (var r in expediente.Recetas.OrderByDescending(x => x.FechaEmision))
                {
                    <div class="border border-slate-100 rounded-xl p-4">
                        <div class="flex items-start justify-between mb-1">
                            <span class="text-sm font-semibold text-blue-700">@r.Medicamento</span>
                            <span class="text-xs px-2 py-0.5 rounded-full @(r.EstaActiva ? "bg-green-100 text-green-700" : "bg-slate-100 text-slate-500")">
                                @(r.EstaActiva ? "ACTIVO" : "EXPIRADO")
                            </span>
                        </div>
                        <p class="text-xs text-slate-500">@r.Dosis</p>
                        @if (!string.IsNullOrWhiteSpace(r.Instrucciones))
                        {
                            <p class="text-xs text-slate-400 mt-1">@r.Instrucciones</p>
                        }
                        <p class="text-xs text-slate-400 mt-2 flex items-center gap-1">
                            <i data-lucide="user" class="w-3 h-3"></i>
                            @r.NombreMedico • @r.FechaEmision.ToString("dd MMM yyyy")
                        </p>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- Modal: Nuevo diagnóstico -->
<div id="modalDiagnostico" class="hidden fixed inset-0 bg-black/30 flex items-center justify-center z-50">
    <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-md mx-4">
        <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold text-slate-800">Nueva Entrada de Diagnóstico</h3>
            <button onclick="document.getElementById('modalDiagnostico').classList.add('hidden')"
                    class="w-7 h-7 rounded-lg flex items-center justify-center text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition-colors">
                <i data-lucide="x" class="w-4 h-4"></i>
            </button>
        </div>
        <form asp-controller="Medico" asp-action="RegistrarDiagnostico" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ExpedienteId" value="@expediente?.Id" />
            <input type="hidden" name="MedicoId" value="@medicoId" />
            <input type="hidden" name="pacienteId" value="@paciente?.Id" />
            <div class="mb-4">
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Descripción</label>
                <textarea name="Descripcion" rows="4" required placeholder="Describe el diagnóstico, hallazgos, indicaciones..."
                          class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 resize-none"></textarea>
            </div>
            <div class="flex gap-2 justify-end">
                <button type="button" onclick="document.getElementById('modalDiagnostico').classList.add('hidden')"
                        class="px-4 py-2 text-sm text-slate-500 hover:bg-slate-50 rounded-xl">Cancelar</button>
                <button type="submit" class="px-4 py-2 text-sm bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-semibold transition-colors">
                    Guardar
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Modal: Emitir receta -->
<div id="modalReceta" class="hidden fixed inset-0 bg-black/30 flex items-center justify-center z-50">
    <div class="bg-white rounded-2xl shadow-xl p-6 w-full max-w-md mx-4">
        <div class="flex items-center justify-between mb-4">
            <h3 class="font-semibold text-slate-800">Emitir Receta</h3>
            <button onclick="document.getElementById('modalReceta').classList.add('hidden')"
                    class="w-7 h-7 rounded-lg flex items-center justify-center text-slate-400 hover:bg-slate-100 hover:text-slate-600 transition-colors">
                <i data-lucide="x" class="w-4 h-4"></i>
            </button>
        </div>
        <form asp-controller="Medico" asp-action="EmitirReceta" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ExpedienteId" value="@expediente?.Id" />
            <input type="hidden" name="MedicoId" value="@medicoId" />
            <input type="hidden" name="pacienteId" value="@paciente?.Id" />
            <div class="mb-3">
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Medicamento</label>
                <input name="Medicamento" required type="text" placeholder="Nombre del medicamento"
                       class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
            </div>
            <div class="mb-3">
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Dosis</label>
                <input name="Dosis" required type="text" placeholder="Ej: 500mg • Dos veces al día • Oral"
                       class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400" />
            </div>
            <div class="mb-4">
                <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Instrucciones</label>
                <textarea name="Instrucciones" rows="2" placeholder="Indicaciones adicionales..."
                          class="w-full px-3 py-2 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-blue-400 resize-none"></textarea>
            </div>
            <div class="flex gap-2 justify-end">
                <button type="button" onclick="document.getElementById('modalReceta').classList.add('hidden')"
                        class="px-4 py-2 text-sm text-slate-500 hover:bg-slate-50 rounded-xl">Cancelar</button>
                <button type="submit" class="flex items-center gap-2 px-4 py-2 text-sm bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-semibold transition-colors">
                    <i data-lucide="file-plus-2" class="w-3.5 h-3.5"></i> Emitir
                </button>
            </div>
        </form>
    </div>
</div>

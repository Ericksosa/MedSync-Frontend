@using MedSync_Frontend.Services
@inject AuthTokenService AuthSvc
@{
    var role = AuthSvc.GetUserRole() ?? "";
    var userName = AuthSvc.GetUserName() ?? AuthSvc.GetUserEmail() ?? "";
    var isAuth = AuthSvc.IsAuthenticated();
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — MedSync</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Inter', 'sans-serif'] }
                }
            }
        }
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
</head>
<body class="bg-slate-50 text-slate-800 flex min-h-screen font-sans">

@if (isAuth)
{
    <!-- Sidebar -->
    <aside class="w-56 min-h-screen bg-white border-r border-slate-100 flex flex-col fixed top-0 left-0 z-30 shadow-sm">
        <!-- Brand -->
        <div class="px-5 py-4 border-b border-slate-100">
            <div class="flex items-center gap-2.5">
                <div class="w-8 h-8 @(role == "SuperAdmin" ? "bg-indigo-600" : "bg-blue-600") rounded-lg flex items-center justify-center text-white shadow-sm">
                    <i data-lucide="@(role == "SuperAdmin" ? "shield" : "cross")" class="w-4 h-4"></i>
                </div>
                <div>
                    <div class="font-bold @(role == "SuperAdmin" ? "text-indigo-700" : "text-blue-700") text-sm leading-tight">MedSync</div>
                    <div class="text-xs text-slate-400 leading-tight">@(role == "SuperAdmin" ? "Sistema Global" : "Tu salud conectada")</div>
                </div>
            </div>
        </div>

        <!-- Nav -->
        <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
            @if (role == "SuperAdmin")
            {
                <a href="/SuperAdmin/Dashboard" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentController=="SuperAdmin" && currentAction=="Dashboard" ? "bg-indigo-50 text-indigo-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="layout-dashboard" class="w-4 h-4 flex-shrink-0"></i> Panel
                </a>
                <a href="/SuperAdmin/Administradores" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentAction=="Administradores" ? "bg-indigo-50 text-indigo-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="user-cog" class="w-4 h-4 flex-shrink-0"></i> Administradores
                </a>
                <a href="/SuperAdmin/Hospitales" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentAction=="Hospitales" ? "bg-indigo-50 text-indigo-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="building-2" class="w-4 h-4 flex-shrink-0"></i> Hospitales
                </a>
                <a href="/SuperAdmin/Usuarios" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentAction=="Usuarios" ? "bg-indigo-50 text-indigo-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="users" class="w-4 h-4 flex-shrink-0"></i> Usuarios
                </a>
            }
            else if (role == "Paciente")
            {
                <a href="/Paciente/Dashboard" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentController=="Paciente" && currentAction=="Dashboard" ? "bg-blue-50 text-blue-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="layout-dashboard" class="w-4 h-4 flex-shrink-0"></i> Dashboard
                </a>
                <a href="/Paciente/ReservarCita" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentAction=="ReservarCita" ? "bg-blue-50 text-blue-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="calendar-plus" class="w-4 h-4 flex-shrink-0"></i> Agendar Cita
                </a>
                <a href="/Paciente/Historial" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentAction=="Historial" ? "bg-blue-50 text-blue-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="clock" class="w-4 h-4 flex-shrink-0"></i> Historial
                </a>
                <a href="/Paciente/Expediente" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentAction=="Expediente" ? "bg-blue-50 text-blue-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="folder-open" class="w-4 h-4 flex-shrink-0"></i> Mi Expediente
                </a>
            }
            else if (role == "Doctor")
            {
                <a href="/Medico/Dashboard" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentController=="Medico" && currentAction=="Dashboard" ? "bg-blue-50 text-blue-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="layout-dashboard" class="w-4 h-4 flex-shrink-0"></i> Dashboard
                </a>
                <a href="/Medico/Agenda" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentAction=="Agenda" ? "bg-blue-50 text-blue-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="calendar" class="w-4 h-4 flex-shrink-0"></i> Citas
                </a>
                <a href="/Medico/Disponibilidad" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentAction=="Disponibilidad" ? "bg-blue-50 text-blue-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="calendar-clock" class="w-4 h-4 flex-shrink-0"></i> Disponibilidad
                </a>
                <a href="/Medico/Historial" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentAction=="Historial" ? "bg-blue-50 text-blue-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="clock" class="w-4 h-4 flex-shrink-0"></i> Historial
                </a>
                <a href="/Medico/CompletarCitas" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentAction=="CompletarCitas" ? "bg-blue-50 text-blue-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="check-square" class="w-4 h-4 flex-shrink-0"></i> Completar Citas
                </a>
            }
            else if (role == "Administrador")
            {
                <a href="/Admin/Dashboard" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentController=="Admin" && currentAction=="Dashboard" ? "bg-blue-50 text-blue-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="layout-dashboard" class="w-4 h-4 flex-shrink-0"></i> Dashboard
                </a>
                <a href="/Admin/Citas" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentAction=="Citas" ? "bg-blue-50 text-blue-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="calendar" class="w-4 h-4 flex-shrink-0"></i> Citas
                </a>
                <a href="/Admin/Pagos" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentAction=="Pagos" ? "bg-blue-50 text-blue-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="credit-card" class="w-4 h-4 flex-shrink-0"></i> Pagos
                </a>
                <a href="/Admin/Cobros" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentAction=="Cobros" ? "bg-blue-50 text-blue-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="receipt" class="w-4 h-4 flex-shrink-0"></i> Cobros
                </a>
                <a href="/Admin/EstadoCuenta" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentAction=="EstadoCuenta" ? "bg-blue-50 text-blue-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="wallet" class="w-4 h-4 flex-shrink-0"></i> Estado de Cuenta
                </a>

                <div class="pt-4 pb-1 px-3 text-xs text-slate-400 uppercase tracking-wider font-semibold">Administración</div>
                <a href="/Admin/Hospitales" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentAction=="Hospitales" ? "bg-blue-50 text-blue-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="building-2" class="w-4 h-4 flex-shrink-0"></i> Hospitales
                </a>
                <a href="/Admin/Medicos" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentAction=="Medicos" ? "bg-blue-50 text-blue-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="stethoscope" class="w-4 h-4 flex-shrink-0"></i> Médicos
                </a>
                <a href="/Admin/Pacientes" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentAction=="Pacientes" ? "bg-blue-50 text-blue-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="users" class="w-4 h-4 flex-shrink-0"></i> Pacientes
                </a>
                <a href="/Admin/Reportes" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm transition-colors @(currentAction=="Reportes" ? "bg-blue-50 text-blue-700 font-semibold" : "text-slate-600 hover:bg-slate-50 hover:text-slate-800")">
                    <i data-lucide="bar-chart-3" class="w-4 h-4 flex-shrink-0"></i> Reportes
                </a>
            }
        </nav>

        <!-- Bottom -->
        <div class="px-3 py-4 border-t border-slate-100 space-y-0.5">
            <a href="/Auth/Logout" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm text-red-500 hover:bg-red-50 transition-colors">
                <i data-lucide="log-out" class="w-4 h-4 flex-shrink-0"></i> Cerrar Sesión
            </a>
        </div>
    </aside>

    <!-- Main content with sidebar offset -->
    <div class="ml-56 flex-1 flex flex-col min-h-screen">
        <!-- Top bar -->
        <header class="bg-white border-b border-slate-100 px-6 py-3 flex items-center justify-between sticky top-0 z-20">
            <div class="text-sm text-slate-500 font-medium">@ViewData["Title"]</div>
            <div class="flex items-center gap-2 relative">
                <button id="btn-notificaciones" type="button" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-400 hover:bg-slate-50 hover:text-slate-600 transition-colors relative">
                    <i data-lucide="bell" class="w-4 h-4"></i>
                    <span id="badge-notificaciones" class="hidden absolute -top-1 -right-1 min-w-[16px] h-4 px-1 rounded-full bg-red-500 text-white text-[10px] leading-4 text-center font-semibold"></span>
                </button>
                <div id="panel-notificaciones" class="hidden absolute right-0 top-11 w-96 max-w-[calc(100vw-2rem)] bg-white border border-slate-200 rounded-xl shadow-xl z-40 overflow-hidden">
                    <div class="px-4 py-3 border-b border-slate-100 flex items-center justify-between">
                        <h3 class="text-sm font-semibold text-slate-700">Notificaciones</h3>
                        <button id="btn-marcar-todas" type="button" class="text-xs text-blue-600 hover:text-blue-700 font-medium">Marcar todas</button>
                    </div>
                    <div id="lista-notificaciones" class="max-h-80 overflow-y-auto divide-y divide-slate-100">
                        <div class="px-4 py-6 text-sm text-slate-500 text-center">Cargando notificaciones...</div>
                    </div>
                </div>
                <button class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-400 hover:bg-slate-50 hover:text-slate-600 transition-colors">
                    <i data-lucide="help-circle" class="w-4 h-4"></i>
                </button>
                <div class="w-px h-5 bg-slate-200 mx-1"></div>
                <a href="/Perfil/Index" class="flex items-center gap-2.5 hover:opacity-80 transition-opacity">
                    <div class="text-right">
                        <div class="text-sm font-semibold text-slate-700 leading-tight">@userName</div>
                        <div class="text-xs leading-tight @(role == "SuperAdmin" ? "text-indigo-500 font-semibold" : "text-slate-400")">
                            @(role == "SuperAdmin" ? "SUPER ADMIN" : role)
                        </div>
                    </div>
                    <div class="w-8 h-8 rounded-full @(role == "SuperAdmin" ? "bg-indigo-600" : "bg-blue-600") text-white text-xs flex items-center justify-center font-bold shadow-sm">
                        @(userName.Length > 0 ? userName[0].ToString().ToUpper() : "U")
                    </div>
                </a>
            </div>
        </header>

        <!-- Page content -->
        <main class="flex-1 p-6">
            @if (TempData["Error"] is string errMsg)
            {
                <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-xl text-sm text-red-700 flex items-center gap-2">
                    <i data-lucide="alert-circle" class="w-4 h-4 flex-shrink-0"></i> @errMsg
                </div>
            }
            @if (TempData["Success"] is string okMsg)
            {
                <div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-xl text-sm text-green-700 flex items-center gap-2">
                    <i data-lucide="check-circle-2" class="w-4 h-4 flex-shrink-0"></i> @okMsg
                </div>
            }
            @RenderBody()
        </main>
    </div>
}
else
{
    <div class="w-full">
        @RenderBody()
    </div>
}

<script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js"></script>
<script>lucide.createIcons();</script>
<script>
    (function () {
        const isAuthenticated = @isAuth.ToString().ToLowerInvariant();
        if (!isAuthenticated) return;

        const bellButton = document.getElementById('btn-notificaciones');
        const panel = document.getElementById('panel-notificaciones');
        const list = document.getElementById('lista-notificaciones');
        const badge = document.getElementById('badge-notificaciones');
        const markAllButton = document.getElementById('btn-marcar-todas');

        if (!bellButton || !panel || !list || !badge || !markAllButton) return;

        function updateBadge(count) {
            if (!count || count <= 0) {
                badge.classList.add('hidden');
                badge.textContent = '';
                return;
            }
            badge.classList.remove('hidden');
            badge.textContent = count > 99 ? '99+' : String(count);
        }

        function escapeHtml(value) {
            return String(value)
                .replace(/&/g, '&amp;')
                .replace(/</g, '&lt;')
                .replace(/>/g, '&gt;')
                .replace(/"/g, '&quot;')
                .replace(/'/g, '&#039;');
        }

        function formatDate(value) {
            if (!value) return '';
            const date = new Date(value);
            if (Number.isNaN(date.getTime())) return '';
            return date.toLocaleString('es-DO', {
                year: 'numeric', month: '2-digit', day: '2-digit',
                hour: '2-digit', minute: '2-digit'
            });
        }

        function renderItems(items) {
            if (!items || items.length === 0) {
                list.innerHTML = '<div class="px-4 py-6 text-sm text-slate-500 text-center">No tienes notificaciones nuevas.</div>';
                return;
            }

            list.innerHTML = items.map(item => {
                const dateText = formatDate(item.fecha);
                const cardClass = item.leida
                    ? 'bg-white hover:bg-slate-50'
                    : 'bg-blue-50/40 hover:bg-blue-50';

                return `
                    <button type="button" data-id="${escapeHtml(item.id)}" data-link="${escapeHtml(item.link || '')}" class="notif-item w-full text-left px-4 py-3 transition-colors ${cardClass}">
                        <div class="flex items-start gap-3">
                            <div class="mt-1 w-2 h-2 rounded-full ${item.leida ? 'bg-slate-300' : 'bg-blue-500'}"></div>
                            <div class="flex-1 min-w-0">
                                <div class="text-sm font-semibold text-slate-700 truncate">${escapeHtml(item.titulo || 'Notificacion')}</div>
                                <div class="text-xs text-slate-600 mt-0.5">${escapeHtml(item.mensaje || '')}</div>
                                ${dateText ? `<div class="text-[11px] text-slate-400 mt-1">${escapeHtml(dateText)}</div>` : ''}
                            </div>
                        </div>
                    </button>`;
            }).join('');

            list.querySelectorAll('.notif-item').forEach(el => {
                el.addEventListener('click', async () => {
                    const id = el.getAttribute('data-id');
                    const link = el.getAttribute('data-link');

                    if (!id) return;
                    try {
                        await fetch('/Notificaciones/MarcarLeida', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ id })
                        });
                    } catch (_) {
                        // Keep UX responsive even if mark-read fails.
                    }

                    if (link) {
                        window.location.href = link;
                        return;
                    }

                    await loadFeed();
                });
            });
        }

        async function loadFeed() {
            try {
                const response = await fetch('/Notificaciones/Feed', { cache: 'no-store' });
                if (!response.ok) throw new Error('No se pudo cargar notificaciones.');

                const data = await response.json();
                updateBadge(data.noLeidas || 0);
                renderItems(data.items || []);
            } catch (_) {
                list.innerHTML = '<div class="px-4 py-6 text-sm text-red-500 text-center">Error al cargar notificaciones.</div>';
                updateBadge(0);
            }
        }

        bellButton.addEventListener('click', async (event) => {
            event.stopPropagation();
            const isHidden = panel.classList.contains('hidden');
            if (isHidden) {
                panel.classList.remove('hidden');
                await loadFeed();
                return;
            }
            panel.classList.add('hidden');
        });

        markAllButton.addEventListener('click', async (event) => {
            event.preventDefault();
            try {
                await fetch('/Notificaciones/MarcarTodasLeidas', { method: 'POST' });
            } catch (_) {
                // Ignore transient network errors.
            }
            await loadFeed();
        });

        document.addEventListener('click', (event) => {
            if (!panel.contains(event.target) && !bellButton.contains(event.target)) {
                panel.classList.add('hidden');
            }
        });

        loadFeed();
    })();
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
